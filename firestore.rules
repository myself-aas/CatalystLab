rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - role: string (optional)
    //
    // Collection: sessions
    // Document ID: {sessionId}
    // Fields:
    //   - userId: string (required) - Must match owner
    //   - title: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: reports
    // Document ID: {reportId}
    // Fields:
    //   - userId: string (required) - Must match owner
    //   - title: string (required)
    //   - content: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: data
    // Document ID: {dataId}
    // Fields:
    //   - userId: string (required) - Must match owner
    //   - content: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasRequiredFields(['email']);
      allow update: if isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
      allow delete: if isOwner(userId);
    }
    
    function isValidSession(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt']) &&
             data.keys().hasOnly(['userId', 'title', 'createdAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.createdAt is timestamp;
    }
    
    // Sessions collection
    match /sessions/{sessionId} {
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow read: if isDocOwner();
      allow update: if isDocOwner() && isValidSession(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    function isValidReport(data) {
      return data.keys().hasAll(['userId', 'title', 'content', 'createdAt']) &&
             data.keys().hasOnly(['userId', 'title', 'content', 'createdAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.createdAt is timestamp;
    }
    
    // Reports collection
    match /reports/{reportId} {
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow read: if isDocOwner();
      allow update: if isDocOwner() && isValidReport(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    function isValidData(data) {
      return data.keys().hasAll(['userId', 'content']) &&
             data.keys().hasOnly(['userId', 'content']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 10000;
    }
    
    // Data collection
    match /data/{dataId} {
      allow create: if isAuthenticated() && isValidData(request.resource.data);
      allow read: if isDocOwner();
      allow update: if isDocOwner() && isValidData(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
